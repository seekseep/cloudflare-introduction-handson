{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hitokoto-api",
  "main": "src/index.js",
  "compatibility_date": "2026-06-01",
  "observability": { "enabled": true },
  // D1（SQLite データベース）の binding。
  // database_id は `npx wrangler d1 create hitokoto-db` で作ったときに表示される ID を貼る。
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "hitokoto-db",
      "database_id": "ここに wrangler d1 create の出力IDを貼る"
    }
  ]
}
